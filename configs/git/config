[core]
  quotepath = false
  editor = nvr --remote-wait-silent
  pager = delta
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true
  process = git-lfs filter-process
[diff "localizablestrings"]
  textconv = "iconv -f utf-16 -t utf-8"
[diff]
  algorithm = histogram
  colorMoved = default
  tool = nvimdiff
  guitool = nvimdiff
[diff "xlsx"]
  binary = true
  textconv = $GOPATH/bin/git-xlsx-textconv
[merge]
  ff = false
  tool = nvimdiff
  conflictstyle = diff3
[push]
  default = simple
  # 初回pushで自動的に --set-upstream (Git 2.37+)
  autoSetupRemote = true
[alias]
  a = add
  b = branch
  co = checkout
  cb = checkout -b
  c = commit -v
  commit = commit -v
  pr = pull-request
  l = log --decorate --stat
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cd) %C(bold blue)<%an>%Creset' --abbrev-commit --date=short
  lga = log --graph --all --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cd) %C(bold blue)<%an>%Creset' --abbrev-commit --date=short
  purge = !git reset --hard HEAD && git clean -fd
  ll = lga
  update = pull --ff --ff-only
  browse = !gh browse
[color]
  ui = true
[mergetool]
  prompt = false
[interactive]
  diffFilter = delta --color-only
[pull]
  autostash = true
  rebase = true
[init]
  defaultBranch = main
[rebase]
  autostash = true
[delta]
  side-by-side = true
  minus-style = syntax "#4b2a3d"
  minus-non-emph-style = syntax "#4b2a3d"
  minus-emph-style = syntax "#e26a75"
  minus-empty-line-marker-style = normal "#4b2a3d"
  plus-style = syntax "#2a4556"
  plus-non-emph-style = syntax "#2a4556"
  plus-emph-style = syntax "#65bcff"
  plus-empty-line-marker-style = normal "#2a4556"
[fetch]
  # fetch時にリモートで削除済みのブランチを自動削除
  prune = true
[rerere]
  enabled = true
[branch]
  sort = -committerdate
[column]
  ui = auto
[merge "mergiraf"]
  name = mergiraf
  driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
